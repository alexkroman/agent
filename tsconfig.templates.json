{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "noEmit": true,
    "paths": {
      "@alexkroman1/aai": ["./packages/aai/mod.ts"],
      "@alexkroman1/aai/types": ["./packages/aai/types.ts"],
      "@alexkroman1/aai-ui": ["./packages/aai-ui/mod.ts"],
      "@alexkroman1/aai-ui/components": ["./packages/aai-ui/components_mod.ts"],
      "@alexkroman1/aai-ui/session": ["./packages/aai-ui/session_mod.ts"],
      "@alexkroman1/aai-ui/styles.css": ["./packages/aai-ui/styles.css"]
    }
  },
  "include": ["packages/aai-cli/templates/*/agent.ts", "packages/aai-cli/templates/*/client.tsx"]
}
