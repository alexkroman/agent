{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "check": "turbo typecheck test && biome check packages/ && tsc -p tsconfig.templates.json && markdownlint-cli2 '**/*.md' '#**/node_modules' '#.aai'",
    "link:global": "node scripts/write-dev-shim.mjs && pnpm --filter @alexkroman1/aai-cli link --global",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@preact/signals": "^2.8.2",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "markdownlint-cli2": "^0.21.0",
    "preact": "^10.29.0",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,mjs}": [
      "biome check --write"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
