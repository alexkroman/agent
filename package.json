{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "vitest run",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "biome check --write packages/",
    "check": "turbo build typecheck lint check:api check:attw check:templates check:knip check:syncpack check:markdown check:integration check:e2e && vitest run --coverage",
    "check:knip": "knip",
    "check:syncpack": "syncpack lint",
    "check:markdown": "markdownlint-cli2 '**/*.md' '#**/node_modules' '#.aai'",
    "syncpack": "syncpack",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish",
    "link:global": "cd packages/aai-cli && pnpm link --global",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.30.0",
    "@microsoft/api-extractor": "^7.57.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "knip": "^6.0.5",
    "lefthook": "^1.12.3",
    "markdownlint-cli2": "^0.22.0",
    "preact": "^10.29.0",
    "syncpack": "^14.2.1",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.6 <25"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "isolated-vm",
      "lefthook"
    ]
  }
}
