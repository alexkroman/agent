{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:integration": "turbo run check:integration",
    "test:e2e": "turbo run check:e2e",
    "test:aai": "pnpm --filter @alexkroman1/aai test",
    "test:aai-ui": "pnpm --filter @alexkroman1/aai-ui test",
    "test:aai-cli": "pnpm --filter @alexkroman1/aai-cli test",
    "test:aai-server": "pnpm --filter @alexkroman1/aai-server test",
    "test:templates": "pnpm --filter @alexkroman1/aai-templates test",
    "aai": "node --experimental-strip-types packages/aai-cli/cli.ts",
    "dev:aai-server": "pnpm --filter @alexkroman1/aai-server dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write packages/",
    "check": "bash scripts/check.sh",
    "check:local": "bash scripts/check.sh --local",
    "check:knip": "knip",
    "check:publint": "turbo run check:publint",
    "check:sherif": "sherif",
    "check:syncpack": "syncpack lint",
    "check:ls-lint": "ls-lint",
    "check:markdown": "markdownlint-cli2 '**/*.md' '#**/node_modules' '#.aai' '#.claude'",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "test:load": "pnpm --filter @alexkroman1/aai-server test:load",
    "syncpack": "syncpack",
    "changeset": "changeset",
    "changeset:create": "bash scripts/create-changeset.sh",
    "version": "changeset version && node scripts/sync-scaffold-versions.mjs",
    "release": "turbo run build && changeset publish",
    "prepare": "[ \"$(git rev-parse --git-dir 2>/dev/null)\" != \"$(git rev-parse --git-common-dir 2>/dev/null)\" ] || lefthook install --force"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@ls-lint/ls-lint": "^2.3.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "citty": "^0.2.2",
    "knip": "^6.3.0",
    "kokoro-js": "^1.2.1",
    "lefthook": "^2.1.5",
    "markdownlint-cli2": "^0.22.0",
    "preact": "^10.29.1",
    "publint": "^0.3.18",
    "sherif": "1.11.1",
    "syncpack": "^14.3.0",
    "toxiproxy-node-client": "^4.0.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=24 <27"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "isolated-vm",
      "lefthook"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "isolated-vm",
      "lefthook",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ],
    "patchedDependencies": {}
  }
}
