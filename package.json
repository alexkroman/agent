{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "pnpm --filter @alexkroman1/aai-cli run test:e2e",
    "test:templates": "vitest run --project templates",
    "test:aai": "vitest run --project aai",
    "test:aai-ui": "vitest run --project aai-ui",
    "test:aai-cli": "vitest run --project aai-cli",
    "test:aai-server": "vitest run --project aai-server",
    "dev:aai-server": "pnpm --filter @alexkroman1/aai-server dev",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "lint:fix": "biome check --write packages/",
    "check": "bash scripts/check.sh",
    "check:local": "bash scripts/check.sh --local",
    "check:knip": "knip",
    "check:publint": "pnpm -r run --if-present check:publint",
    "check:syncpack": "syncpack lint",
    "check:markdown": "markdownlint-cli2 '**/*.md' '#**/node_modules' '#.aai' '#.claude'",
    "syncpack": "syncpack",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r run build && changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "publint": "^0.3.15",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "knip": "^6.0.6",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.22.0",
    "preact": "^10.29.0",
    "syncpack": "^14.2.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.6 <25"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "isolated-vm",
      "lefthook"
    ],
    "onlyBuiltDependencies": [],
    "patchedDependencies": {
      "eventsource-parser@3.0.6": "patches/eventsource-parser@3.0.6.patch"
    }
  }
}
