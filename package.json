  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/fs-extra": "^11",
    "@types/minimist": "^1.2",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/ws": "^8.18.1",
    "ink-testing-library": "^4",
    "linkedom": "^0.18.10",
    "typescript": "^5.7",
    "vitest": "^3.1"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
