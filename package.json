{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "vitest run",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "biome check --write packages/",
    "check": "turbo typecheck lint && vitest run && tsc -p packages/aai-cli/tsconfig.templates.json && markdownlint-cli2 '**/*.md' '#**/node_modules' '#.aai'",
    "syncpack": "syncpack",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish",
    "link:global": "pnpm --filter @alexkroman1/aai-cli link --global",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@changesets/cli": "^2.30.0",
    "@preact/signals": "^2.8.2",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "markdownlint-cli2": "^0.21.0",
    "preact": "^10.29.0",
    "syncpack": "^14.2.1",
    "turbo": "^2.8.20",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx,js,mjs}": [
      "biome check --write"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  }
}
