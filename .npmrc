# Disable pnpm's verify-deps-before-run check. When `pnpm exec`/`pnpm run` is
# invoked (e.g. `pnpm exec turbo run lint typecheck`) against a restored CI
# cache whose workspace-state file is missing/empty, the check crashes with
# "Unexpected end of JSON input" in loadWorkspaceState. CI verifies deps
# explicitly via `pnpm install --frozen-lockfile` instead.
verify-deps-before-run=false
