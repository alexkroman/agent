{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '^git (push|commit)'; then echo 'IMPORTANT: Before committing, run pnpm check:local (typecheck + lint + syncpack + tests). This catches version drift in template package.json, lint issues in non-staged files, and test assertion mismatches — the top causes of fix-up commits. If you have not run it yet, abort this action and run pnpm check:local first.'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'IMPORTANT: Subscribe to this PR using subscribe_pr_activity and monitor for CI failures and review comments. If CI fails, investigate the failure, fix the code, commit, and push. Continue monitoring until CI passes.'"
          }
        ]
      },
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm install --frozen-lockfile 2>/dev/null || pnpm install",
            "timeout": 120,
            "statusMessage": "Installing worktree dependencies..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$(git rev-parse --git-dir 2>/dev/null)\" != \"$(git rev-parse --git-common-dir 2>/dev/null)\" ] || npx lefthook install --force"
          },
          {
            "type": "command",
            "command": "pnpm install --frozen-lockfile 2>/dev/null || pnpm install",
            "timeout": 120,
            "statusMessage": "Installing dependencies..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm check*)",
      "Bash(bash scripts/check*)",
      "Bash(pnpm build*)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm run *)",
      "Bash(npx vitest *)",
      "Bash(pnpm -r *)",
      "Bash(npx biome *)",
      "Bash(npx tsc *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash*)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git cherry-pick *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__search_pull_requests",
      "mcp__github__subscribe_pr_activity",
      "mcp__github__unsubscribe_pr_activity",
      "mcp__github__create_pull_request",
      "mcp__github__update_pull_request",
      "mcp__github__update_pull_request_branch",
      "mcp__github__add_issue_comment",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__get_commit"
    ]
  },
  "includeGitInstructions": true
}
