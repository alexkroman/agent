{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'IMPORTANT: Subscribe to this PR using subscribe_pr_activity and monitor for CI failures and review comments. If CI fails, investigate the failure, fix the code, commit, and push. Continue monitoring until CI passes.'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx lefthook install"
          },
          {
            "type": "command",
            "command": "pnpm install --frozen-lockfile 2>/dev/null || pnpm install",
            "timeout": 120,
            "statusMessage": "Installing dependencies..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm check*)",
      "Bash(pnpm build*)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm run *)",
      "Bash(npx vitest *)",
      "Bash(pnpm -r *)",
      "Bash(npx biome *)",
      "Bash(npx tsc *)",
      "Bash(npx api-extractor *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash*)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git cherry-pick *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)"
    ]
  },
  "includeGitInstructions": true
}
