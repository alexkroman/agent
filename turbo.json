{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.test-d.ts", "tsconfig*.json", "tsdown.config.ts"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "vitest.config.ts", "../../vitest.shared.ts"],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "vitest.config.ts", "../../vitest.shared.ts"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "!**/*.test.ts", "!**/*.test.tsx", "tsconfig*.json"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "biome.json"]
    },
    "check:publint": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "package.json"]
    },
    "check:attw": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "package.json"]
    },
    "check:integration": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "vitest.integration.config.ts", "../../vitest.shared.ts"]
    },
    "check:e2e": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx"]
    },
    "check:harness": {
      "dependsOn": ["build"]
    },
    "check:typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
