{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "check:api": {
      "dependsOn": ["build"]
    },
    "check:attw": {
      "dependsOn": ["build"]
    },
    "check:templates": {
      "dependsOn": ["^build"]
    },
    "check:integration": {
      "dependsOn": ["^build"]
    },
    "check:e2e": {
      "dependsOn": ["^build"]
    },
    "//#check:knip": {},
    "//#check:syncpack": {},
    "//#check:markdown": {}
  }
}
