{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": "node_modules/.cache/turbo",
  "globalDependencies": ["pnpm-lock.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "**/*.tsx", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.test-d.ts", "tsconfig*.json", "tsdown.config.ts", "package.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": [],
      "inputs": ["**/*.ts", "**/*.tsx", "vitest.config.ts", "../../vitest.shared.ts"],
      "env": ["CI"]
    },
    "test:coverage": {
      "dependsOn": [],
      "inputs": ["**/*.ts", "**/*.tsx", "vitest.config.ts", "../../vitest.shared.ts"],
      "outputs": ["coverage/**"],
      "env": ["CI"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "!**/*.test.ts", "!**/*.test.tsx", "tsconfig*.json"]
    },
    "lint": {
      "inputs": ["**/*.ts", "**/*.tsx", "biome.json"]
    },
    "check:publint": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "package.json"]
    },
    "check:attw": {
      "dependsOn": ["build"],
      "inputs": ["dist/**", "package.json"]
    },
    "check:integration": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "vitest.integration.config.ts", "../../vitest.shared.ts"]
    },
    "check:e2e": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx"]
    },
    "check:load": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "load/**/*.ts", "../../docker-compose.yml", "Dockerfile"]
    },
    "check:adversarial": {
      "dependsOn": ["build", "check:load"],
      "inputs": ["**/*.ts", "adversarial/**/*.ts", "../../docker-compose.yml", "Dockerfile"]
    },
    "check:typecheck": {
      "dependsOn": ["^build"]
    },
    "//#check:syncpack": {
      "inputs": ["package.json", "packages/*/package.json", ".syncpackrc.json"]
    },
    "//#check:sherif": {
      "inputs": ["package.json", "packages/*/package.json", "pnpm-workspace.yaml"]
    },
    "//#check:knip": {
      "inputs": ["packages/**/*.ts", "packages/**/*.tsx", "knip.json", "package.json", "packages/*/package.json"]
    },
    "//#check:markdown": {
      "inputs": ["**/*.md"]
    }
  }
}
