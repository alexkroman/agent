# Dockerfile.test — Run all tests in a Linux environment.
#
# Fast iteration: no kernel build, no guest images. Just the full
# project with all deps installed, ready to run any test command.
#
# Usage:
#   ./scripts/docker-test.sh                  # run all tests
#   ./scripts/docker-test.sh pnpm check:local # run check:local
#   ./scripts/docker-test.sh pnpm vitest run packages/aai-server/sandbox-vm.test.ts

FROM node:24-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl git unzip \
    && rm -rf /var/lib/apt/lists/*

# Install Deno — needed for sandbox tests
RUN curl -fsSL https://deno.land/install.sh | DENO_INSTALL=/usr/local sh

RUN corepack enable && corepack prepare pnpm@10.29.3 --activate

# Layer 1: workspace config + lockfile (cached unless deps change)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/aai-core/package.json packages/aai-core/
COPY packages/aai-ui/package.json packages/aai-ui/
COPY packages/aai-cli/package.json packages/aai-cli/
COPY packages/aai-server/package.json packages/aai-server/
COPY packages/aai-templates/package.json packages/aai-templates/

RUN pnpm install --frozen-lockfile --ignore-scripts --prod=false

# Layer 2: source (busted on any code change, but deps layer is cached)
COPY . .

# Build all packages
RUN pnpm -r run build

# Init a git repo so scripts that check git state don't fail
RUN git init && git add -A && git commit -m "docker build" --allow-empty \
    --author="docker <docker@test>" 2>/dev/null || true

CMD ["pnpm", "test"]
