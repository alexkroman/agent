{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "paths": {
      "aai": ["../aai/index.ts"],
      "aai-ui": ["../aai-ui/index.ts"]
    }
  },
  "include": [
    "css.d.ts",
    "templates/*/tools.ts",
    "templates/*/client.tsx",
    "templates/*/shared.ts",
    "templates/*/_shared.ts"
  ]
}
