{
  "name": "@alexkroman1/aai-ui",
  "version": "0.12.3",
  "type": "module",
  "files": [
    "dist",
    "styles.css"
  ],
  "exports": {
    ".": {
      "@dev/source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "check:publint": "publint",
    "check:attw": "attw --pack --profile esm-only --entrypoints ."
  },
  "dependencies": {
    "aai": "workspace:*",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai-ui"
  }
}
