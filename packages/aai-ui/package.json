{
  "name": "@alexkroman1/aai-ui",
  "version": "0.12.3",
  "type": "module",
  "files": [
    "dist",
    "styles.css"
  ],
  "exports": {
    ".": {
      "@dev/source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./session": {
      "@dev/source": "./session.ts",
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "check:publint": "publint",
    "check:attw": "attw --pack --profile esm-only --entrypoints . ./session"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "@preact/signals": "^2.9.0",
    "preact": "^10.29.1",
    "tailwindcss": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@preact/signals": "^2.9.0",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^29.0.1",
    "preact": "^10.29.1",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai-ui"
  }
}
