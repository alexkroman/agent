{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "incremental": false,
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "**/lib/test-utils.ts"]
}
