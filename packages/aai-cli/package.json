{
  "name": "@alexkroman1/aai-cli",
  "version": "1.0.1",
  "type": "module",
  "bin": {
    "aai": "bin.mjs"
  },
  "publishConfig": {
    "bin": {
      "aai": "dist/cli.mjs"
    }
  },
  "exports": {
    "./types": {
      "@dev/source": "./types.ts",
      "import": "./dist/types.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:e2e": "VITEST_PROFILE=e2e VITEST_INCLUDE=e2e.test.ts vitest run -c ../../vitest.slow.config.ts",
    "check:e2e": "pnpm run test:e2e"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@clack/prompts": "^1.2.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "dotenv": "^17.4.1",
    "giget": "^3.2.0",
    "p-debounce": "^5.1.0",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "get-port": "^7.2.0",
    "playwright": "^1.59.1",
    "tree-kill": "^1.2.2",
    "tsdown": "^0.21.7",
    "verdaccio": "^6.4.0",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "vitest": "^4.1.3"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai-cli"
  }
}
