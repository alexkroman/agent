{
  "name": "@alexkroman1/aai-cli",
  "version": "0.12.3",
  "type": "module",
  "bin": {
    "aai": "dist/cli.mjs"
  },
  "exports": {
    "./testing": {
      "@dev/source": "./testing.ts",
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./testing/matchers": {
      "@dev/source": "./matchers.ts",
      "types": "./dist/matchers.d.ts",
      "import": "./dist/matchers.js"
    },
    "./types": {
      "@dev/source": "./types.ts",
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:e2e": "vitest run e2e.test.ts -c vitest.slow.config.ts",
    "check:e2e": "pnpm run test:e2e",
    "test:docker": "vitest run --config vitest.docker.config.ts"
  },
  "dependencies": {
    "@alexkroman1/aai-core": "workspace:*",
    "@clack/prompts": "^1.2.0",
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "esbuild": "^0.28.0",
    "giget": "^3.2.0",
    "unstorage": "^1.17.5",
    "vite": "^8.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "get-port": "^7.2.0",
    "playwright": "^1.59.1",
    "tree-kill": "^1.2.2",
    "tsdown": "^0.21.7",
    "verdaccio": "^6.4.0",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "vitest": "^4.1.3"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai-cli"
  }
}
