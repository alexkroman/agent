{
  "name": "@alexkroman1/aai",
  "version": "0.12.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "@dev/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./isolate": {
      "@dev/source": "./src/isolate/index.ts",
      "types": "./dist/isolate/index.d.ts",
      "import": "./dist/isolate/index.js"
    },
    "./host": {
      "@dev/source": "./src/host/index.ts",
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.js"
    },
    "./server": {
      "@dev/source": "./src/host/server.ts",
      "types": "./dist/host/server.d.ts",
      "import": "./dist/host/server.js"
    },
    "./types": {
      "@dev/source": "./src/isolate/types.ts",
      "types": "./dist/isolate/types.d.ts",
      "import": "./dist/isolate/types.js"
    },
    "./kv": {
      "@dev/source": "./src/isolate/kv.ts",
      "types": "./dist/isolate/kv.d.ts",
      "import": "./dist/isolate/kv.js"
    },
    "./protocol": {
      "@dev/source": "./src/isolate/protocol.ts",
      "types": "./dist/isolate/protocol.d.ts",
      "import": "./dist/isolate/protocol.js"
    },
    "./testing": {
      "@dev/source": "./src/host/testing.ts",
      "types": "./dist/host/testing.d.ts",
      "import": "./dist/host/testing.js"
    },
    "./testing/matchers": {
      "@dev/source": "./src/host/matchers.ts",
      "types": "./dist/host/matchers.d.ts",
      "import": "./dist/host/matchers.js"
    },
    "./hooks": {
      "@dev/source": "./src/isolate/hooks.ts",
      "types": "./dist/isolate/hooks.d.ts",
      "import": "./dist/isolate/hooks.js"
    },
    "./utils": {
      "@dev/source": "./src/isolate/lib/utils.ts",
      "types": "./dist/isolate/lib/utils.d.ts",
      "import": "./dist/isolate/lib/utils.js"
    },
    "./vite-plugin": {
      "@dev/source": "./src/host/vite-plugin.ts",
      "types": "./dist/host/vite-plugin.d.ts",
      "import": "./dist/host/vite-plugin.js"
    }
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p src/isolate/tsconfig.json",
    "lint": "biome check .",
    "check:publint": "publint",
    "check:attw": "attw --pack --profile esm-only"
  },
  "dependencies": {
    "hookable": "^6.1.0",
    "nanoevents": "^9.1.0",
    "p-timeout": "^7.0.1",
    "unstorage": "^1.17.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "vitest": "^4.1.1"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.5",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">=22.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai"
  }
}
