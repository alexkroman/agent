{
  "name": "@alexkroman1/aai",
  "version": "1.8.3",
  "type": "module",
  "exports": {
    ".": {
      "@dev/source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "@dev/source": "./sdk/protocol.ts",
      "types": "./dist/sdk/protocol.d.ts",
      "import": "./dist/sdk/protocol.js"
    },
    "./runtime": {
      "@dev/source": "./host/runtime-barrel.ts",
      "types": "./dist/host/runtime-barrel.d.ts",
      "import": "./dist/host/runtime-barrel.js"
    },
    "./manifest": {
      "@dev/source": "./sdk/manifest-barrel.ts",
      "types": "./dist/sdk/manifest-barrel.d.ts",
      "import": "./dist/sdk/manifest-barrel.js"
    },
    "./stt": {
      "@dev/source": "./sdk/providers/stt-barrel.ts",
      "types": "./dist/sdk/providers/stt-barrel.d.ts",
      "import": "./dist/sdk/providers/stt-barrel.js"
    },
    "./tts": {
      "@dev/source": "./sdk/providers/tts-barrel.ts",
      "types": "./dist/sdk/providers/tts-barrel.d.ts",
      "import": "./dist/sdk/providers/tts-barrel.js"
    },
    "./llm": {
      "@dev/source": "./sdk/providers/llm-barrel.ts",
      "types": "./dist/sdk/providers/llm-barrel.d.ts",
      "import": "./dist/sdk/providers/llm-barrel.js"
    },
    "./vector": {
      "@dev/source": "./sdk/providers/vector-barrel.ts",
      "types": "./dist/sdk/providers/vector-barrel.d.ts",
      "import": "./dist/sdk/providers/vector-barrel.js"
    },
    "./kv": {
      "@dev/source": "./sdk/providers/kv-barrel.ts",
      "types": "./dist/sdk/providers/kv-barrel.d.ts",
      "import": "./dist/sdk/providers/kv-barrel.js"
    },
    "./s2s": {
      "@dev/source": "./sdk/providers/s2s-barrel.ts",
      "types": "./dist/sdk/providers/s2s-barrel.d.ts",
      "import": "./dist/sdk/providers/s2s-barrel.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "VITEST_INCLUDE=host/integration.test.ts,host/pentest.test.ts,host/run-code-sandbox.test.ts vitest run -c ../../vitest.slow.config.ts",
    "check:integration": "pnpm run test:integration",
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p sdk/tsconfig.json",
    "lint": "biome check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/google": "^4.0.16",
    "@ai-sdk/groq": "^4.0.11",
    "@ai-sdk/mistral": "^4.0.11",
    "@ai-sdk/openai": "^4.0.14",
    "@ai-sdk/xai": "^4.0.13",
    "@cartesia/cartesia-js": "^3.3.0",
    "@deepgram/sdk": "^5.5.0",
    "@elevenlabs/elevenlabs-js": "^2.58.0",
    "ai": "^7.0.28",
    "assemblyai": "^4.36.3",
    "escape-html": "^1.0.3",
    "html-to-text": "^10.0.0",
    "mime-types": "^3.0.2",
    "nanoevents": "^9.1.0",
    "p-event": "^7.1.0",
    "p-timeout": "^7.0.1",
    "unstorage": "^1.17.5",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@pinecone-database/pinecone": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "@pinecone-database/pinecone": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pinecone-database/pinecone": "^8.0.0",
    "@types/escape-html": "^1.0.4",
    "@types/html-to-text": "^9.0.4",
    "@types/json-schema": "^7.0.15",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.22.8",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai"
  }
}
