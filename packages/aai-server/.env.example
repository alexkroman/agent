# AAI Platform Server — copy to .env and fill in values
PORT=8787

# Required
BUCKET_NAME=aai-agents
KV_SCOPE_SECRET=change-me-to-a-random-secret

# Tigris S3 (bundle storage)
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Upstash Redis (KV store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector (optional — RAG)
# UPSTASH_VECTOR_REST_URL=
# UPSTASH_VECTOR_REST_TOKEN=
