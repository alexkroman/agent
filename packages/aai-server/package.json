{
  "name": "@alexkroman1/aai-server",
  "version": "0.9.16",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "predev": "node -e \"const [maj,min] = process.versions.node.split('.').map(Number); if (maj < 22 || (maj === 22 && min < 6)) { console.error('Node >=22.6 required (got ' + process.version + '). Run: fnm use 22'); process.exit(1); }\"",
    "dev": "node --watch index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run --exclude 'load/**' --exclude 'adversarial/**'",
    "test:coverage": "vitest run --coverage --exclude 'load/**' --exclude 'adversarial/**'",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check:integration": "pnpm run test:integration",
    "test:docker": "vitest run --config vitest.docker.config.ts",
    "test:firecracker": "vitest run --config vitest.firecracker.config.ts",
    "test:load": "vitest run --config load/vitest.load.config.ts",
    "check:load": "pnpm run test:load"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "bogon": "^1.2.0",
    "hono": "^4.12.12",
    "hookable": "^6.1.0",
    "human-id": "^4.1.3",
    "lru-cache": "^11.3.2",
    "mime-types": "^3.0.2",
    "p-lock": "^4.0.1",
    "p-timeout": "^7.0.1",
    "unstorage": "^1.17.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "testcontainers": "^11.14.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.6"
  }
}
