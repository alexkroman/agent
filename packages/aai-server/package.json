{
  "name": "aai-server",
  "version": "1.0.20",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "predev": "node -e \"const [maj] = process.versions.node.split('.').map(Number); if (maj < 24) { console.error('Node >=24 required (got ' + process.version + '). Run: fnm use 24'); process.exit(1); }\"",
    "dev": "node --conditions=@dev/source index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run --exclude 'load/**' --exclude 'adversarial/**'",
    "test:coverage": "vitest run --coverage --exclude 'load/**' --exclude 'adversarial/**'",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:integration": "VITEST_INCLUDE=orchestrator-integration.test.ts,ws-integration.test.ts,fake-vm-integration.test.ts,gvisor-integration.test.ts vitest run -c ../../vitest.slow.config.ts",
    "check:integration": "pnpm run test:integration",
    "test:docker": "VITEST_PROFILE=docker VITEST_INCLUDE=docker-build.test.ts vitest run -c ../../vitest.slow.config.ts",
    "test:gvisor": "VITEST_PROFILE=gvisor VITEST_INCLUDE=packages/aai-server/gvisor-integration.test.ts vitest run -c ../../vitest.slow.config.ts",
    "test:load": "vitest run --config load/vitest.load.config.ts",
    "check:load": "pnpm run test:load",
    "test:adversarial": "vitest run --config adversarial/vitest.adversarial.config.ts",
    "check:adversarial": "pnpm run test:adversarial"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@alexkroman1/aai-ui": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "bogon": "^1.2.0",
    "hono": "^4.12.14",
    "human-id": "^4.1.3",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.9",
    "p-lock": "^4.0.1",
    "p-timeout": "^7.0.1",
    "unstorage": "^1.17.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "testcontainers": "^11.14.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24"
  }
}
