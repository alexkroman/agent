{
  "name": "@alexkroman1/aai-server",
  "version": "0.9.12",
  "private": true,
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "predev": "node -e \"const [maj,min] = process.versions.node.split('.').map(Number); if (maj < 22 || (maj === 22 && min < 6)) { console.error('Node >=22.6 required (got ' + process.version + '). Run: fnm use 22'); process.exit(1); }\"",
    "dev": "node --watch src/index.ts",
    "start": "node dist/index.mjs",
    "build": "tsdown",
    "check:harness": "node --experimental-strip-types scripts/check-harness.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check:integration": "pnpm run test:integration"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.9",
    "hookable": "^6.1.0",
    "lru-cache": "^11.2.7",
    "mime-types": "^3.0.2",
    "p-lock": "^4.0.1",
    "p-timeout": "^7.0.1",
    "secure-exec": "^0.1.0",
    "unstorage": "^1.17.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@secure-exec/typescript": "^0.1.0",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=22.6"
  }
}
