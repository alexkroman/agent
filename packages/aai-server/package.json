{
  "name": "@alexkroman1/aai-server",
  "version": "0.9.3",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "predev": "node -e \"const [maj,min] = process.versions.node.split('.').map(Number); if (maj < 22 || (maj === 22 && min < 6)) { console.error('Node >=22.6 required (got ' + process.version + '). Run: fnm use 22'); process.exit(1); }\"",
    "dev": "node --watch --env-file=.env src/index.ts",
    "start": "node dist/index.mjs",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@hono/node-server": "^1.19.11",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "mime-types": "^3.0.2",
    "secure-exec": "^0.1.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@smithy/types": "^4.13.1",
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.5"
  },
  "engines": {
    "node": ">=22.6"
  }
}
