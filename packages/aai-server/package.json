{
  "name": "@alexkroman1/aai-server",
  "version": "0.8.8",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "predev": "node -e \"const v = +process.versions.node.split('.')[0]; if (v < 22 || v >= 25) { console.error('Node 22 required (got ' + process.version + '). Run: fnm use 22'); process.exit(1); }\"",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && tsx build_harness.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test:integration": "pnpm build && node dist/sandbox_integration.js"
  },
  "dependencies": {
    "@alexkroman1/aai": "workspace:*",
    "@aws-sdk/client-s3": "^3.1016.0",
    "@hono/node-server": "^1.19.11",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "hono": "^4.12.8",
    "jose": "^6.2.2",
    "mime-types": "^3.0.2",
    "prom-client": "^15.1.3",
    "secure-exec": "*",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
