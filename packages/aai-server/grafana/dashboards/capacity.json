{
  "uid": "aai-capacity",
  "title": "aai-agent / Capacity",
  "tags": ["aai-agent"],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "default" },
        "hide": 0
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(up{app=\"aai-agent\"}, instance)",
          "refId": "Variable-instance-Variable-Query"
        },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Fleet capacity used",
      "description": "Max % across all six saturation dimensions. 100% = at the operational ceiling.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(\n  label_replace(100 * sum(process_resident_memory_bytes) / (sum(aai_machine_memory_bytes) * 0.8), \"dim\", \"memory\", \"\", \"\")\n  or label_replace(100 * sum(rate(process_cpu_seconds_total[5m])) / (sum(aai_machine_cpu_cores) * 0.7), \"dim\", \"cpu\", \"\", \"\")\n  or label_replace(100 * (max(nodejs_eventloop_lag_p99_seconds) / 0.05), \"dim\", \"event_loop\", \"\", \"\")\n  or label_replace(100 * histogram_quantile(0.95, sum by (le) (rate(aai_sandbox_init_seconds_bucket{path=\"cold\"}[5m]))), \"dim\", \"cold_start\", \"\", \"\")\n  or label_replace(100 * (sum(rate(aai_sessions_ended_total{reason=\"error\"}[5m])) / clamp_min(sum(rate(aai_sessions_started_total[5m])), 1) / 0.01), \"dim\", \"session_error\", \"\", \"\")\n  or label_replace((100 * ((1 - sum(aai_warm_pool_ready) / clamp_min(sum(aai_warm_pool_target), 1)) / 0.5)) unless on() (sum(aai_warm_pool_target) == 0), \"dim\", \"warm_pool\", \"\", \"\")\n)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory headroom",
      "description": "Fraction of memory ceiling (machine RAM × 0.8) still available across the fleet.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - 100 * sum(process_resident_memory_bytes) / (sum(aai_machine_memory_bytes) * 0.8)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU headroom",
      "description": "Fraction of CPU ceiling (cores × 0.7) still available across the fleet.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 - 100 * sum(rate(process_cpu_seconds_total[5m])) / (sum(aai_machine_cpu_cores) * 0.7)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "SLO burn",
      "description": "Max of event-loop p99, cold-start p95, and session-error rate, each as % of its SLO threshold.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "max(\n  label_replace(100 * (max(nodejs_eventloop_lag_p99_seconds) / 0.05), \"dim\", \"event_loop\", \"\", \"\")\n  or label_replace(100 * histogram_quantile(0.95, sum by (le) (rate(aai_sandbox_init_seconds_bucket{path=\"cold\"}[5m]))), \"dim\", \"cold_start\", \"\", \"\")\n  or label_replace(100 * (sum(rate(aai_sessions_ended_total{reason=\"error\"}[5m])) / clamp_min(sum(rate(aai_sessions_started_total[5m])), 1) / 0.01), \"dim\", \"session_error\", \"\", \"\")\n)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Warm pool ready",
      "description": "Ready / target across fleet. <50% means pool is starving and cold starts are likely.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum(aai_warm_pool_ready) / clamp_min(sum(aai_warm_pool_target), 1) unless on() (sum(aai_warm_pool_target) == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 75 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "All saturation dimensions over time",
      "description": "Each line is a dimension's % of its operational ceiling. 100% = at SLO. >100% = breaching.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * sum(process_resident_memory_bytes) / (sum(aai_machine_memory_bytes) * 0.8)",
          "legendFormat": "memory",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(process_cpu_seconds_total[5m])) / (sum(aai_machine_cpu_cores) * 0.7)",
          "legendFormat": "cpu",
          "refId": "B"
        },
        {
          "expr": "100 * (max(nodejs_eventloop_lag_p99_seconds) / 0.05)",
          "legendFormat": "event-loop p99",
          "refId": "C"
        },
        {
          "expr": "100 * histogram_quantile(0.95, sum by (le) (rate(aai_sandbox_init_seconds_bucket{path=\"cold\"}[5m])))",
          "legendFormat": "cold-start p95",
          "refId": "D"
        },
        {
          "expr": "100 * (sum(rate(aai_sessions_ended_total{reason=\"error\"}[5m])) / clamp_min(sum(rate(aai_sessions_started_total[5m])), 1) / 0.01)",
          "legendFormat": "session errors",
          "refId": "E"
        },
        {
          "expr": "100 * ((1 - sum(aai_warm_pool_ready) / clamp_min(sum(aai_warm_pool_target), 1)) / 0.5) unless on() (sum(aai_warm_pool_target) == 0)",
          "legendFormat": "warm pool",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 150,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Active sessions vs theoretical sandbox cap",
      "description": "Active sessions, plus a constant line for the max sandboxes that fit within the 80% memory ceiling at the 64 MB cgroup cap.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(aai_sessions_active)",
          "legendFormat": "active sessions",
          "refId": "A"
        },
        {
          "expr": "sum(aai_machine_memory_bytes) * 0.8 / (64 * 1024 * 1024)",
          "legendFormat": "theoretical max sandboxes",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory % per instance",
      "description": "process_resident_memory_bytes / aai_machine_memory_bytes per instance. SLO line at 80%.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * process_resident_memory_bytes{instance=~\"$instance\"} / on(instance) aai_machine_memory_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 80 }]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU % per instance",
      "description": "rate(process_cpu_seconds_total[5m]) / aai_machine_cpu_cores per instance. SLO line at 70%.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "100 * rate(process_cpu_seconds_total{instance=~\"$instance\"}[5m]) / on(instance) aai_machine_cpu_cores",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 70 }]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Event-loop lag p99 per instance",
      "description": "Per-instance event-loop p99 in seconds. SLO line at 0.05 s (50 ms).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Sandbox cold-start p95 per instance",
      "description": "Per-instance cold-start p95 over 5m. SLO line at 1 s.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (instance, le) (rate(aai_sandbox_init_seconds_bucket{path=\"cold\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1.0 }]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 }
    }
  ]
}
