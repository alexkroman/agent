{
  "uid": "aai-agents",
  "title": "aai-agent / Agents",
  "tags": ["aai-agent"],
  "schemaVersion": 39,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "default" },
        "hide": 0
      },
      {
        "name": "slug",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": {
          "query": "label_values(aai_sessions_started_total, slug)",
          "refId": "Variable-slug-Variable-Query"
        },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Top 10 sessions started (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (slug) (rate(aai_sessions_started_total[5m])))",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true } } }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top 10 active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (slug) (aai_sessions_active))",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true } } }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Top 10 error rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum by (slug) (rate(aai_sessions_ended_total{reason=\"error\"}[5m])) / clamp_min(sum by (slug) (rate(aai_sessions_started_total[5m])), 1))",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true } } }],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active sessions ($slug)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (slug) (aai_sessions_active{slug=~\"$slug\"})",
          "legendFormat": "{{slug}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Start rate ($slug)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (slug) (rate(aai_sessions_started_total{slug=~\"$slug\"}[5m]))",
          "legendFormat": "{{slug}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "End-reason breakdown ($slug)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(aai_sessions_ended_total{slug=~\"$slug\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error ratio ($slug)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(aai_sessions_ended_total{slug=~\"$slug\",reason=\"error\"}[5m])) / clamp_min(sum(rate(aai_sessions_started_total{slug=~\"$slug\"}[5m])), 1)",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
