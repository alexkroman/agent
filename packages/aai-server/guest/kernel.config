# Minimal Linux kernel config for Firecracker guests.
#
# This config produces a vmlinux suitable for booting inside Firecracker VMM.
# It enables only what is strictly necessary: vsock IPC, initrd boot, devtmpfs,
# and the serial console. All networking, USB, GPU, sound, ACPI, PCI, and
# filesystem drivers are disabled to keep the image small and attack surface minimal.
#
# To rebuild vmlinux from this config:
#   cp kernel.config linux-6.1/.config
#   make -C linux-6.1 olddefconfig
#   make -C linux-6.1 vmlinux -j$(nproc)
#
# Or use build-kernel.sh which automates the above steps.

# 64-bit x86
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=2

# Basic kernel infrastructure
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_LOCALVERSION=""
CONFIG_DEFAULT_HOSTNAME="firecracker-guest"

# initrd support
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
# CONFIG_RD_BZIP2 is not set
# CONFIG_RD_LZMA is not set
# CONFIG_RD_XZ is not set
# CONFIG_RD_LZO is not set
# CONFIG_RD_LZ4 is not set
# CONFIG_RD_ZSTD is not set

# Virtual filesystems (tmpfs required by kernel internally)
CONFIG_TMPFS=y
# CONFIG_EXT4_FS is not set
# CONFIG_EXT3_FS is not set
# CONFIG_EXT2_FS is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_PROC_FS is not set
# CONFIG_SYSFS is not set

# Device filesystem (needed for /dev/null, /dev/urandom)
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Serial console (Firecracker uses this for early output)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_TTY=y

# Virtio base (required by vsock)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y

# vsock — the only IPC mechanism between guest and host
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# Disable modules entirely (monolithic kernel)
# CONFIG_MODULES is not set

# Disable networking stack
# CONFIG_NET is not set
# CONFIG_INET is not set
# CONFIG_IPV6 is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BLUETOOTH is not set

# Disable block devices and storage drivers
# CONFIG_BLOCK is not set
# CONFIG_BLK_DEV is not set
# CONFIG_SCSI is not set
# CONFIG_ATA is not set
# CONFIG_NVME_CORE is not set
# CONFIG_MMC is not set
# CONFIG_USB_STORAGE is not set

# Disable USB
# CONFIG_USB is not set
# CONFIG_USB_SUPPORT is not set

# Disable PCI
# CONFIG_PCI is not set
# CONFIG_PCCARD is not set

# Disable ACPI
# CONFIG_ACPI is not set

# Disable GPU and DRM
# CONFIG_DRM is not set
# CONFIG_VGA_ARB is not set
# CONFIG_FB is not set

# Disable sound
# CONFIG_SOUND is not set
# CONFIG_SND is not set

# Disable input devices
# CONFIG_INPUT is not set
# CONFIG_HID is not set
# CONFIG_HID_SUPPORT is not set

# Disable power management
# CONFIG_PM is not set
# CONFIG_SUSPEND is not set
# CONFIG_HIBERNATION is not set
# CONFIG_CPU_FREQ is not set

# Disable hardware monitoring and misc sensors
# CONFIG_HWMON is not set
# CONFIG_MFD_SUPPORT is not set
# CONFIG_WATCHDOG is not set

# Minimal memory management
CONFIG_MEMCG=y
CONFIG_SHMEM=y

# Compiler options for small image
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
