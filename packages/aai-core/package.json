{
  "name": "@alexkroman1/aai-core",
  "version": "0.12.3",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "@dev/source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "@dev/source": "./isolate/protocol.ts",
      "types": "./dist/isolate/protocol.d.ts",
      "import": "./dist/isolate/protocol.js"
    },
    "./runtime": {
      "@dev/source": "./host/runtime-barrel.ts",
      "types": "./dist/host/runtime-barrel.d.ts",
      "import": "./dist/host/runtime-barrel.js"
    },
    "./manifest": {
      "@dev/source": "./isolate/manifest-barrel.ts",
      "types": "./dist/isolate/manifest-barrel.d.ts",
      "import": "./dist/isolate/manifest-barrel.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check:integration": "pnpm run test:integration",
    "build": "tsdown && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit && tsc -p isolate/tsconfig.json",
    "lint": "biome check ."
  },
  "dependencies": {
    "nanoevents": "^9.1.0",
    "p-timeout": "^7.0.1",
    "unstorage": "^1.17.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.7",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexkroman/agent.git",
    "directory": "packages/aai-core"
  }
}
