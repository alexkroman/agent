{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreUnresolved": ["./_jsdom-setup.ts", "./sdk/_test-matchers.ts"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["exports", "types", "optionalPeerDependencies", "duplicates"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}", "vitest.adversarial.config.ts", "stryker*.config.mjs"],
      "ignoreDependencies": ["ws", "@stryker-mutator/api"]
    },
    "packages/aai": {
      "entry": [
        "host/_test-utils.ts",
        "host/runtime-barrel.ts",
        "host/providers/stt-barrel.ts",
        "host/providers/tts-barrel.ts",
        "host/integration/**/*.integration.test.ts",
        "**/*.test.ts",
        "**/*.test-d.ts"
      ],
      "includeEntryExports": true
    },
    "packages/aai-ui": {
      "entry": ["**/*.test.{ts,tsx}", "_react-test-utils.ts", "default-client.tsx"],
      "includeEntryExports": true
    },
    "packages/aai-cli": {
      "entry": ["**/*.test.ts", "_test-utils.ts", "bin.mjs", "types.ts"]
    },
    "packages/aai-templates": {
      "ignore": ["**"]
    },
    "packages/aai-server": {
      "entry": ["**/*.test.ts", "guest/fake-vm.ts"],
      "includeEntryExports": true,
      "ignoreDependencies": ["@types/json-schema"]
    }
  }
}
