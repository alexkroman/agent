{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreUnresolved": ["./_jsdom-setup.ts"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["exports", "types", "optionalPeerDependencies", "duplicates"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}", "vitest.adversarial.config.ts"],
      "ignoreDependencies": ["ws"]
    },
    "packages/aai": {
      "entry": [
        "index.ts",
        "host/runtime-barrel.ts",
        "sdk/manifest-barrel.ts",
        "host/_test-utils.ts",
        "**/*.test.ts"
      ],
      "includeEntryExports": true
    },
    "packages/aai-ui": {
      "entry": ["**/*.test.{ts,tsx}", "_react-test-utils.ts", "default-client.tsx"],
      "includeEntryExports": true
    },
    "packages/aai-cli": {
      "entry": ["bin.mjs", "types.ts", "**/*.test.ts", "_test-utils.ts"]
    },
    "packages/aai-templates": {
      "ignore": ["**"]
    },
    "packages/aai-server": {
      "entry": ["**/*.test.ts", "guest/fake-vm.ts"],
      "includeEntryExports": true,
      "ignoreDependencies": ["@types/json-schema"]
    }
  }
}
