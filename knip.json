{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreUnresolved": ["./_jsdom-setup.ts", "./host/matchers.ts", "../aai/host/matchers.ts"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["exports", "types", "optionalPeerDependencies"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"]
    },
    "packages/aai": {
      "entry": ["**/*.test.ts", "host/_test-utils.ts"],
      "includeEntryExports": true
    },
    "packages/aai-ui": {
      "entry": ["**/*.test.{ts,tsx}", "_test-utils.ts"],
      "includeEntryExports": true
    },
    "packages/aai-cli": {
      "entry": ["**/*.test.ts", "_test-utils.ts"]
    },
    "packages/aai-templates": {
      "ignore": ["**"]
    },
    "packages/aai-server": {
      "entry": ["**/*.test.ts"],
      "includeEntryExports": true
    }
  }
}
