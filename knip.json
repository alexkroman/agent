{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreUnresolved": ["./_jsdom-setup.ts"],
  "ignoreExportsUsedInFile": true,
  "exclude": ["exports", "types", "optionalPeerDependencies"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.{mjs,ts}", "vitest.adversarial.config.ts"],
      "ignoreDependencies": ["ws"]
    },
    "packages/aai-core": {
      "entry": [
        "index.ts",
        "host/runtime-barrel.ts",
        "isolate/manifest-barrel.ts",
        "host/_test-utils.ts",
        "**/*.test.ts"
      ],
      "includeEntryExports": true
    },
    "packages/aai-ui": {
      "entry": ["**/*.test.{ts,tsx}", "**/*.test-d.ts", "_react-test-utils.ts"],
      "includeEntryExports": true
    },
    "packages/aai-cli": {
      "entry": ["**/*.test.ts", "_test-utils.ts", "testing.ts", "matchers.ts", "types.ts"]
    },
    "packages/aai-templates": {
      "ignore": ["**"]
    },
    "packages/aai-server": {
      "entry": ["**/*.test.ts", "guest/fake-vm.ts", "guest/deno-harness.ts"],
      "includeEntryExports": true,
      "ignoreDependencies": ["@types/json-schema"]
    }
  }
}
