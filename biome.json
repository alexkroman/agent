{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "files": {
    "includes": [
      "packages/**",
      "!**/node_modules",
      "!**/dist",
      "!**/.aai",
      "!**/__snapshots__",
      "!**/templates",
      "!packages/aai-templates",
      "!tmp"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "recommended": true,
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUndeclaredDependencies": "error",
        "useImportExtensions": "error",
        "noGlobalDirnameFilename": "error",
        "noPrivateImports": "error",
        "noUnresolvedImports": "off"
      },
      "style": {
        "recommended": true,
        "noNonNullAssertion": "error",
        "useNodejsImportProtocol": "error",
        "useConsistentBuiltinInstantiation": "error",
        "useCollapsedElseIf": "error",
        "useExplicitLengthCheck": "error",
        "useForOf": "error",
        "useThrowNewError": "error",
        "useThrowOnlyError": "error",
        "noDefaultExport": "off",
        "useNamingConvention": "off",
        "useFilenamingConvention": "error",
        "useBlockStatements": "off",
        "noParameterAssign": "error",
        "useConsistentArrayType": "error",
        "noEnum": "error",
        "noShoutyConstants": "error",
        "useImportType": "error",
        "noNestedTernary": "error",
        "useNumberNamespace": "error",
        "noUselessElse": "error",
        "noCommonJs": "error",
        "noExportedImports": "error",
        "noSubstr": "error",
        "useTrimStartEnd": "error",
        "useDefaultParameterLast": "error",
        "useAtIndex": "error",
        "noDoneCallback": "error",
        "noNamespace": "error",
        "noParameterProperties": "error",
        "noUnusedTemplateLiteral": "error",
        "noYodaExpression": "error",
        "useAsConstAssertion": "error",
        "useCollapsedIf": "error",
        "useConsistentArrowReturn": "error",
        "useConsistentCurlyBraces": "error",
        "useDefaultSwitchClause": "error",
        "useNodeAssertStrict": "error",
        "useNumericSeparators": "error",
        "useUnifiedTypeSignatures": "error"
      },
      "suspicious": {
        "recommended": true,
        "noExplicitAny": "error",
        "noConsole": "off",
        "noEmptyBlockStatements": "error",
        "useErrorMessage": "error",
        "noMisplacedAssertion": "error",
        "noAssignInExpressions": "error",
        "noDoubleEquals": "error",
        "noEvolvingTypes": "error",
        "noSkippedTests": "warn",
        "useGuardForIn": "error",
        "noConstantBinaryExpressions": "error",
        "noDeprecatedImports": "error",
        "noDuplicateDependencies": "error",
        "noExportsInTest": "error",
        "noFocusedTests": "error",
        "noImportCycles": "error",
        "noUnusedExpressions": "error"
      },
      "complexity": {
        "recommended": true,
        "noExcessiveCognitiveComplexity": "error",
        "noStaticOnlyClass": "error",
        "useDateNow": "error",
        "useSimplifiedLogicExpression": "error",
        "noForEach": "error",
        "noUselessUndefinedInitialization": "error",
        "noUselessStringConcat": "error",
        "noExcessiveNestedTestSuites": "error",
        "noImplicitCoercions": "error",
        "noUselessCatchBinding": "error",
        "noUselessUndefined": "error",
        "useWhile": "error"
      },
      "performance": {
        "useTopLevelRegex": "off",
        "noAccumulatingSpread": "error",
        "noReExportAll": "error"
      },
      "security": {
        "recommended": true,
        "noSecrets": "error"
      },
      "a11y": {
        "recommended": false
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "noNestedPromises": "error",
        "noConditionalExpect": "error",
        "noUnnecessaryConditions": "error",
        "noUselessReturn": "error",
        "noMultiAssign": "error",
        "noMultiStr": "error",
        "noProto": "error",
        "noReturnAssign": "error",
        "noScriptUrl": "error",
        "noRedundantDefaultExport": "error",
        "noParametersOnlyUsedInRecursion": "error",
        "useArraySome": "error",
        "useArraySortCompare": "error",
        "useExhaustiveSwitchCases": "error",
        "useFind": "error",
        "useSpread": "error",
        "useImportsFirst": "error",
        "useErrorCause": "error",
        "useNullishCoalescing": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/_test-utils.ts",
        "**/_jsdom-setup.ts",
        "**/vitest*.config.ts"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredDependencies": "off"
          },
          "nursery": {
            "noConditionalExpect": "off",
            "useImportsFirst": "off"
          },
          "security": {
            "noSecrets": "off"
          },
          "suspicious": {
            "noExportsInTest": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
